# AI 提供商 (google, deepseek, openai, moonshot, custom)
AI_PROVIDER=google
# 你的 API Key
AI_API_KEY=your_api_key_here
# 模型名称 (例如: gemini-1.5-flash, deepseek-chat)
AI_MODEL_NAME=gemini-1.5-flash

# (可选) 自定义 Base URL，仅在 AI_PROVIDER=custom 时必填
# AI_BASE_URL=https://api.your-provider.com/v1
# ======== Alibaba Cloud DashScope (Qwen) ========
AI_PROVIDER=custom
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL_NAME=qwen-coder-plus